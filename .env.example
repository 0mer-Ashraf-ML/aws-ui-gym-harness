# Backend
APP_NAME="RL Gym Harness Task Runner"
VERSION=1.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8000
DATABASE_URL=postgresql://app_user:password@localhost:5432/rl_gym_harness
SECRET_KEY=your-secret-key-change-this-in-production-make-it-long-and-random
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback
ADMIN_EMAILS=admin@example.com,admin2@example.com
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_ORG=your_openai_org_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
SCRAPYBARA_API_KEY=your_scrapybara_api_key_here
BROWSERBASE_API_KEY=your_browserbase_api_key_here
BROWSERBASE_PROJECT_ID=your_browserbase_project_id_here
TASKS_CSV_PATH=tasks/production_tasks.csv
CSV_FILE=tasks/production_tasks.csv
DEFAULT_TASK_ID=clear-cart
RESULTS_DIR=results
ENABLE_STREAMLIT_CAPTURE=true
CAPTURE_STREAMLIT_REQUESTS=true
CAPTURE_STREAMLIT_API_CALLS=true
CAPTURE_STREAMLIT_ELEMENTS=true
MAX_WAIT_TIME=180
CHECK_INTERVAL=2
MAX_RETRIES=3
RETRY_DELAY=2
STREAMLIT_LOAD_DELAY=1
VERIFICATION_DELAY=1
DOCKER_LOAD_DELAY=1
IFRAME_LOAD_DELAY=1
BROWSER_WIDTH=1920
BROWSER_HEIGHT=1080
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:8501
CUA_URL=http://localhost:8080
STREAMLIT_URL=http://localhost:8501
WS_HEARTBEAT_INTERVAL=30
MIN_RESPONSE_LENGTH=100
DEFAULT_MAX_ITERATIONS=100
DEFAULT_TIMEOUT_MINUTES=6
CELERY_WORKER_CONCURRENCY=10

# Frontend
VITE_API_URL=http://localhost:8000
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
